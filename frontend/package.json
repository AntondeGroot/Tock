{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --no-watch --coverage",
    "e2e": "playwright test",
    "prettier": "prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "openapi-generator-cli generate -i ../keezenspel_openapi.yml -g typescript-angular -o src/app/api --additional-properties=ngVersion=22.0.0,fileNaming=kebab-case",
    "postinstall": "npm run generate:api",
    "prebuild": "npm run generate:api",
    "lint": "ng lint --max-warnings=0",
    "lint:fix": "ng lint --fix",
    "prepare": "cd .. && husky frontend/.husky || true"
  },
  "private": true,
  "packageManager": "npm@12.0.1",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@openapitools/openapi-generator-cli": "^2.39.0",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "22.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "typescript": "~7.0.0",
    "typescript-eslint": "8.65.0",
    "vitest": "^4.0.8"
  }
}
